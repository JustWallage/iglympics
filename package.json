{
  "name": "iglympics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "vite",
    "dev:pages": "wrangler d1 migrations apply iglympics-local --local && wrangler pages dev",
    "migrate:local": "echo y | wrangler d1 migrations apply iglympics-local --local",
    "build": "node scripts/music-manifest.mjs && tsc && vite build",
    "check:ts": "tsc --noEmit",
    "check:tf:fmt": "cd iac && terraform fmt -check",
    "check:tf:validate": "cd iac && terraform validate",
    "check:tf": "pnpm run check:tf:fmt && pnpm run check:tf:validate",
    "check": "pnpm run check:ts && pnpm run check:tf:fmt && pnpm run check:tf",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "tf:init": "cd iac && terraform init -backend=false",
    "seed:local": "tsx scripts/seed-db.ts iglympics2024 iglympics-local",
    "prepare": "husky",
    "wrangler:login": "wrangler login"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "tailwind-merge": "^3.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.0",
    "vite": "^6.3.1",
    "wrangler": "^4.14.0"
  }
}
